# Telegram bot
TELEGRAM_TOKEN=1234567890:YOUR_BOT_TOKEN
ADMIN_IDS=111111111,222222222

# Billing
DEVICE_MONTHLY_PRICE=100

# SSH defaults
SSH_KEY_PATH=/root/.ssh/id_rsa

# Servers (new format, preferred)
# Add as many servers as needed using SERVER_<N>_* variables.
SERVER_1_NAME=Server1
SERVER_1_HOST=203.0.113.10
SERVER_1_PORT=22
SERVER_1_SSH_USER=root
SERVER_1_SSH_KEY_PATH=/root/.ssh/id_rsa
SERVER_1_WG_INTERFACE=wg0
SERVER_1_WG_CONFIG_PATH=/opt/amnezia/awg/wg0.conf
SERVER_1_IS_LOCAL=true

SERVER_2_NAME=Server2
SERVER_2_HOST=198.51.100.20
SERVER_2_PORT=22
SERVER_2_SSH_USER=root
SERVER_2_SSH_KEY_PATH=/root/.ssh/id_rsa
SERVER_2_WG_INTERFACE=wg0
SERVER_2_WG_CONFIG_PATH=/opt/amnezia/awg/wg0.conf
SERVER_2_IS_LOCAL=false

# Legacy compatibility (optional; use either legacy vars or SERVER_<N>_* format)
# GHISLAIN_HOST=
# POTAPOV_HOST=
# ALEV_HOST=
# RCP_HOST=

# Backup sync repository (used by scripts/backup_vpn_configs.py)
BACKUP_GIT_REPO_URL=git@github.com:your-org/your-backup-repo.git
BACKUP_GIT_LOCAL_DIR=/root/vpn_backup_repo
BACKUP_GIT_BRANCH=main
